# Copy this file to backend/.env and fill in your key.
# backend/.env is gitignored.

# Required for the AI Assistant. Get one free at:
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Optional. Defaults to gemini-2.5-flash.
# GOOGLE_AI_MODEL=gemini-2.5-flash

# Optional. Cloud Postgres connection string (e.g. from Neon). When set, the app
# uses this instead of the local SQLite file. Leave unset for local SQLite.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-west-2.aws.neon.tech/dbname?sslmode=require
