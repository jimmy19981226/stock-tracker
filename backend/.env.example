# Copy this file to backend/.env and fill in your key.
# backend/.env is gitignored.

# Required for the AI Assistant. Get one free at:
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Optional. Defaults to gemini-2.5-flash.
# GOOGLE_AI_MODEL=gemini-2.5-flash

# Optional. Cloud Postgres connection string (e.g. from Neon). When set, the app
# uses this instead of the local SQLite file. Leave unset for local SQLite.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-west-2.aws.neon.tech/dbname?sslmode=require

# Required for Google sign-in (the iOS app). This is your Google OAuth client ID;
# the backend verifies that ID tokens were minted for THIS client (audience
# check). Without it, any authenticated request is rejected with 503 — set it
# whenever you accept Google logins. Leave unset only for fully un-authenticated
# (legacy-bucket) use.
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Web dashboard (read-only) password gate + which user's data it shows.
# WEB_DASHBOARD_PASSWORD unlocks the dashboard; WEB_DASHBOARD_USER_ID selects the
# data scope it reads (defaults to "legacy"). See app/routers/webauth.py.
# WEB_DASHBOARD_PASSWORD=
# WEB_DASHBOARD_USER_ID=legacy
